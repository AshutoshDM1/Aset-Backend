{
  "name": "aset-monorepo",
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm --filter aset-frontend dev",
    "dev:backend": "pnpm --filter aset-backend dev",
    "build:frontend": "pnpm --filter aset-frontend build",
    "build:vercel": "pnpm --filter aset-backend exec prisma generate && pnpm --filter aset-frontend build ",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
