{
  "name": "aset-backend",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target=bun",
    "start": "bun run dist/index.js",
    "push": "bunx prisma db push",
    "pull": "bunx prisma db pull",
    "gen": "bunx prisma generate",
    "migrate": "bunx prisma migrate dev",
    "studio": "bunx prisma studio",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "prepare": "husky",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/node": "^25.3.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "prettier": "3.8.1",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.58.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@clerk/backend": "^3.2.8",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@trpc/server": "^11.10.0",
    "dotenv": "^17.4.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  }
}
